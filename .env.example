# ========================================
# 클라이밍 날씨 TGTWTG 봇 - 환경 변수 설정
# ========================================
# 
# 사용 방법: 이 파일을 .env로 복사해서 아래 값들을 입력하세요
# cp .env.example .env

# ========================================
# [필수] Telegram 설정
# ========================================

# Telegram Bot Token
# BotFather(@botfather)에서 /newbot으로 생성: https://t.me/botfather
# 예: 123456789:ABCDefGHijKLmnoPQRstuvWXYz-abcdefghI
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID
# 봇에 /start 명령 실행 후, logs/weather_bot.log에서 확인
# 또는 @userinfobot 사용: https://t.me/userinfobot
# 예: 1234567890
TELEGRAM_CHAT_ID=your_chat_id_here

# ========================================
# [필수] Weather API 설정
# ========================================

# OpenWeather API Key
# https://openweathermap.org/api에서 Free 회원가입 후 생성
# 1,000건/일 제한 (Free Plan)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ========================================
# [선택] 향후 추가 예정
# ========================================

# 한국 기상청 API Key (아직 미사용 - 향후 추가 예정)
KMA_API_KEY=your_korea_meteorological_admin_key_here

# ========================================
# 클라이밍 지역 설정
# ========================================

# 클라이밍 지역 설정 파일 경로 (기본값 유지 권장)
CLIMBING_SITES_CONFIG=config/sites.json

# ========================================
# 아침 자동 리포트 시간 설정
# ========================================

# 아침 자동 알림 시간 (시간, 0-23)
# 기본값: 7 (아침 7시)
SCHEDULE_HOUR=7

# 아침 자동 알림 시간 (분, 0-59)
# 기본값: 0 (정각)
# 예: 7시 30분 = SCHEDULE_HOUR=7, SCHEDULE_MINUTE=30
SCHEDULE_MINUTE=0

# ========================================
# 로깅 설정
# ========================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# 기본값: INFO
LOG_LEVEL=INFO

# ========================================
# 주의사항
# ========================================
# - .env 파일은 .gitignore에 포함되어 있습니다 (보안)
# - API 키는 절대로 GitHub에 업로드하지 마세요
# - .env 파일 수정 후 봇을 재시작하세요
# - Chat ID가 틀리면 봇이 메시지를 전송할 수 없습니다

